{
  "name": "block-of-out-line",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm run start:dev -w packages/server",
    "dev:admin": "npm run dev -w packages/admin",
    "build:server": "npm run build -w packages/server",
    "build:admin": "npm run build -w packages/admin",
    "build": "npm run build:server && npm run build:admin",
    "test:server": "npm run test -w packages/server"
  }
}
